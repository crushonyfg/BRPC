    "delta_logp = {}\n",
    "for name in data.keys():\n",
    "    w_max_hist = []\n",
    "    delta_logp_hist = []\n",
    "    for i in range(len(data[name][\"others\"][-1][\"report_hist\"])):\n",
    "        et = data[name][\"others\"][-1][\"report_hist\"][i][1]\n",
